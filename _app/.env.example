# RISS 수집기 자격증명 설정 (선택)
#
# GUI 앱 사용자는 이 파일이 필요 없습니다.
#   → 앱 첫 실행 화면에서 대학·ID·PW를 입력하면 OS 보안 저장소(Keychain/DPAPI)에 저장됩니다.
#
# CLI 또는 MCP로 직접 실행할 때만 이 파일을 사용합니다.
#   1. 이 파일을 복사해 이름을 .env 로 변경 (이 폴더 또는 ~/.riss/.env)
#   2. 아래 값을 본인 정보로 채우기
#
# 읽기 우선순위: 현재 폴더 .env → _app/.env → ~/.riss/.env

# 도서관 이용자 ID (학번)
RISS_ID=

# 도서관 비밀번호
RISS_PW=

# 대학 ID — hufs(한국외대), korea(고려대), cnu(충남대), snu(서울대),
#           skku(성균관대), khu(경희대), pusan(부산대), konkuk(건국대),
#           kookmin(국민대), cbnu(충북대)
RISS_UNIVERSITY=hufs
