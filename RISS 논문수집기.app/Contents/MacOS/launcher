#!/bin/bash
# RISS 논문수집기 .app launcher

# PATH 확장 — .app 실행 시 PATH가 최소화되므로 Node.js 설치 경로를 직접 추가
export PATH="/usr/local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/bin:/bin:$PATH"
[ -s "$HOME/.nvm/nvm.sh" ]  && source "$HOME/.nvm/nvm.sh" --no-use
[ -d "$HOME/.volta/bin" ]   && export PATH="$HOME/.volta/bin:$PATH"
[ -d "$HOME/.fnm" ]         && eval "$(fnm env 2>/dev/null)"

THIS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RISS_DIR="$(cd "$THIS_DIR/../../../" && pwd)"
APP_DIR="$RISS_DIR/_app"
CONFIG_DIR="$HOME/.riss"
PORT_FILE="$CONFIG_DIR/port"
LOG_FILE="$CONFIG_DIR/server.log"

mkdir -p "$CONFIG_DIR"

# Node.js 확인
if ! command -v node &>/dev/null; then
  osascript -e 'display dialog "Node.js가 필요합니다.\n\nnodejs.org 에서 LTS 버전을 설치한 뒤 다시 실행해 주세요." with title "RISS 논문수집기" buttons {"확인"} default button "확인" with icon stop'
  exit 1
fi

# 이미 실행 중인 서버 확인
if [ -f "$PORT_FILE" ]; then
  PORT=$(cat "$PORT_FILE" 2>/dev/null)
  if [ -n "$PORT" ] && curl -sf "http://127.0.0.1:$PORT/api/config" >/dev/null 2>&1; then
    open "http://127.0.0.1:$PORT"
    exit 0
  fi
  rm -f "$PORT_FILE"
fi

# _app 폴더 확인
if [ ! -d "$APP_DIR" ]; then
  osascript -e "display dialog \"앱 폴더를 찾을 수 없습니다.\n\n예상 경로: $APP_DIR\" with title \"RISS 논문수집기\" buttons {\"확인\"} with icon stop"
  exit 1
fi

# 패키지 설치 (최초 1회)
if [ ! -d "$APP_DIR/node_modules" ]; then
  osascript -e 'display notification "패키지 설치 중입니다. 잠시 기다려 주세요..." with title "RISS 논문수집기"'
  cd "$APP_DIR" && npm install --production --silent 2>>"$LOG_FILE"
fi

# Playwright 브라우저 확인
if [ ! -d "$HOME/.cache/ms-playwright" ] && [ ! -d "$HOME/Library/Caches/ms-playwright" ]; then
  osascript -e 'display notification "브라우저를 설치하고 있습니다. 1~2분 소요됩니다..." with title "RISS 논문수집기"'
  cd "$APP_DIR" && npx playwright install chromium 2>>"$LOG_FILE"
fi

# 서버 시작
cd "$APP_DIR"
node launcher/server.js >>"$LOG_FILE" 2>&1 &

# 서버 준비 대기
for i in $(seq 1 30); do
  sleep 0.5
  if [ -f "$PORT_FILE" ]; then
    PORT=$(cat "$PORT_FILE" 2>/dev/null)
    if [ -n "$PORT" ] && curl -sf "http://127.0.0.1:$PORT/api/config" >/dev/null 2>&1; then
      # 첫 실행 안내 (1회만)
      FIRST_RUN="$CONFIG_DIR/.first_run_done"
      if [ ! -f "$FIRST_RUN" ]; then
        touch "$FIRST_RUN"
        CHOICE=$(osascript -e 'display dialog "처음 실행하셨군요!\n\n다른 기기에 배포 시 보안 차단이 뜰 경우:\n시스템 설정 → 개인정보 보호 및 보안\n→ 화면 하단 \"그래도 열기\" 클릭\n\n지금 시스템 설정을 여시겠어요?" with title "RISS 논문수집기" buttons {"닫기", "시스템 설정 열기"} default button "닫기" with icon note' 2>/dev/null)
        [[ "$CHOICE" == *"시스템 설정 열기"* ]] && open "x-apple.systempreferences:com.apple.preference.security"
      fi
      open "http://127.0.0.1:$PORT"
      exit 0
    fi
  fi
done

osascript -e "display dialog \"서버 시작에 실패했습니다.\n\n로그 파일: $LOG_FILE\" with title \"RISS 논문수집기\" buttons {\"확인\"} with icon stop"
exit 1
